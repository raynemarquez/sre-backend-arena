# .env.example — template de variáveis de ambiente
# Copie para .env e preencha os valores reais
# O arquivo .env NUNCA deve ser commitado (está no .gitignore)

# ---------------------------------------------------------------------------
# Aplicação
# ---------------------------------------------------------------------------
APP_ENV=local                    # local | staging | production
APP_VERSION=1.0.0

# ---------------------------------------------------------------------------
# HP API
# ---------------------------------------------------------------------------
HP_API_BASE_URL=https://hp-api.onrender.com/api

# ---------------------------------------------------------------------------
# OpenTelemetry (Traces → Tempo)
# Deixe vazio para desabilitar tracing (útil em dev sem Tempo rodando)
# ---------------------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=    # ex: http://tempo.monitoring.svc:4318
OTEL_SERVICE_NAME=wizard-intelligence-network

# ---------------------------------------------------------------------------
# Rate limiter client-side para a HP-API
# Ajuste conforme os limites reais da API
# ---------------------------------------------------------------------------
HP_API_RATE_LIMIT_RPS=10
HP_API_RATE_LIMIT_BURST=20
