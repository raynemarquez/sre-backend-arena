{
  "uid": "wizard-sre-dashboard",
  "title": "Wizard Intelligence Network — SRE Dashboard",
  "tags": ["sre", "wizard", "harry-potter"],
  "timezone": "browser",
  "refresh": "30s",
  "schemaVersion": 38,
  "time": { "from": "now-1h", "to": "now" },
  "panels": [

    {
      "id": 1,
      "title": "🏆 SLO — Disponibilidade (alvo: 99.9%)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
      "targets": [{
        "expr": "sum(rate(api_requests_total{job=\"kubernetes-pods-wizard\", http_status!~\"5..\"}[5m])) / sum(rate(api_requests_total{job=\"kubernetes-pods-wizard\"}[5m])) * 100",
        "legendFormat": "Disponibilidade %"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 99 },
              { "color": "green", "value": 99.9 }
            ]
          },
          "mappings": []
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "area" }
    },

    {
      "id": 2,
      "title": "⚡ Latência p99 (alvo: < 300ms)",
      "type": "stat",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
      "targets": [{
        "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=\"kubernetes-pods-wizard\"}[5m])) by (le)) * 1000",
        "legendFormat": "p99 ms"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 150 },
              { "color": "red", "value": 300 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" }
    },

    {
      "id": 3,
      "title": "🔥 Taxa de Erros",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
      "targets": [{
        "expr": "sum(rate(api_requests_total{job=\"kubernetes-pods-wizard\", http_status=~\"5..\"}[5m])) / sum(rate(api_requests_total{job=\"kubernetes-pods-wizard\"}[5m])) * 100",
        "legendFormat": "Erros 5xx %"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 2,
          "noValue": "0%",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.1 },
              { "color": "red", "value": 0.5 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" }
    },

    {
      "id": 4,
      "title": "⚔️ Circuit Breaker",
      "type": "stat",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
      "targets": [{
        "expr": "circuit_breaker_open{job=\"kubernetes-pods-wizard\"}",
        "legendFormat": "Estado"
      }],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "FECHADO ✅", "color": "green", "index": 0 } } },
            { "type": "value", "options": { "1": { "text": "ABERTO 🚨", "color": "red", "index": 1 } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },

    {
      "id": 5,
      "title": "📈 Golden Signal — Throughput (RPS)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
      "targets": [
        {
          "expr": "sum(rate(api_requests_total{job=\"kubernetes-pods-wizard\"}[1m]))",
          "legendFormat": "Total RPS"
        },
        {
          "expr": "sum(rate(api_requests_total{job=\"kubernetes-pods-wizard\", http_status=\"200\"}[1m]))",
          "legendFormat": "2xx RPS"
        },
        {
          "expr": "sum(rate(api_requests_total{job=\"kubernetes-pods-wizard\", http_status=\"404\"}[1m]))",
          "legendFormat": "404 RPS"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "2xx RPS" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "404 RPS" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] }
        ]
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },

    {
      "id": 6,
      "title": "⏱️ Golden Signal — Latência p50 / p95 / p99",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{job=\"kubernetes-pods-wizard\"}[1m])) by (le)) * 1000",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"kubernetes-pods-wizard\"}[1m])) by (le)) * 1000",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=\"kubernetes-pods-wizard\"}[1m])) by (le)) * 1000",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "lineWidth": 2, "fillOpacity": 5 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 150 },
              { "color": "red", "value": 300 }
            ]
          }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "p99" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "p95" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "p50" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] }
        ]
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },

    {
      "id": 7,
      "title": "🎯 Golden Signal — Erros por Tipo",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
      "targets": [
        {
          "expr": "sum(rate(api_requests_total{job=\"kubernetes-pods-wizard\", http_status=\"404\"}[1m]))",
          "legendFormat": "404 Not Found"
        },
        {
          "expr": "sum(rate(api_requests_total{job=\"kubernetes-pods-wizard\", http_status=~\"5..\"}[1m]))",
          "legendFormat": "5xx Server Error"
        },
        {
          "expr": "sum(rate(api_errors_total{job=\"kubernetes-pods-wizard\"}[1m])) by (type)",
          "legendFormat": "{{type}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "color": { "mode": "palette-classic" }
        }
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },

    {
      "id": 8,
      "title": "📦 Cache Hit Rate",
      "type": "gauge",
      "gridPos": { "x": 12, "y": 12, "w": 6, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
      "targets": [{
        "expr": "sum(rate(cache_hits_total{job=\"kubernetes-pods-wizard\"}[5m])) / (sum(rate(cache_hits_total{job=\"kubernetes-pods-wizard\"}[5m])) + sum(rate(cache_misses_total{job=\"kubernetes-pods-wizard\"}[5m]))) * 100",
        "legendFormat": "Cache Hit %"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "green", "value": 85 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdLabels": true, "showThresholdMarkers": true }
    },

    {
      "id": 9,
      "title": "📊 Cache Hits vs Misses",
      "type": "timeseries",
      "gridPos": { "x": 18, "y": 12, "w": 6, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
      "targets": [
        {
          "expr": "sum(rate(cache_hits_total{job=\"kubernetes-pods-wizard\"}[1m]))",
          "legendFormat": "Hits/s"
        },
        {
          "expr": "sum(rate(cache_misses_total{job=\"kubernetes-pods-wizard\"}[1m]))",
          "legendFormat": "Misses/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Hits/s" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Misses/s" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] }
        ]
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },

    {
      "id": 10,
      "title": "📊 SLO — Error Budget Consumido (SLO 99.9%)",
      "type": "gauge",
      "gridPos": { "x": 0, "y": 20, "w": 8, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
      "targets": [{
        "expr": "(1 - sum(rate(api_requests_total{job=\"kubernetes-pods-wizard\", http_status!~\"5..\"}[1h])) / sum(rate(api_requests_total{job=\"kubernetes-pods-wizard\"}[1h]))) / (1 - 0.999) * 100",
        "legendFormat": "Error Budget %"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "min": 0,
          "max": 100,
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdLabels": false, "showThresholdMarkers": true }
    },

    {
      "id": 11,
      "title": "🔄 Latência Média por Endpoint",
      "type": "bargauge",
      "gridPos": { "x": 8, "y": 20, "w": 8, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
      "targets": [{
        "expr": "sum(rate(http_request_duration_seconds_sum{job=\"kubernetes-pods-wizard\"}[5m])) by (endpoint) / sum(rate(http_request_duration_seconds_count{job=\"kubernetes-pods-wizard\"}[5m])) by (endpoint) * 1000",
        "legendFormat": "{{endpoint}}"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 300 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "horizontal", "displayMode": "gradient", "valueMode": "color" }
    },

    {
      "id": 12,
      "title": "🖥️ CPU Usage (processo)",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 20, "w": 8, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
      "targets": [{
        "expr": "sum(rate(process_cpu_seconds_total{job=\"kubernetes-pods-wizard\"}[1m])) * 100",
        "legendFormat": "CPU %"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 80 }
            ]
          }
        }
      },
      "options": { "tooltip": { "mode": "single" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },

    {
      "id": 13,
      "title": "💾 Memória RSS (processo)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 26, "w": 8, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
      "targets": [{
        "expr": "sum(process_resident_memory_bytes{job=\"kubernetes-pods-wizard\"}) / 1024 / 1024",
        "legendFormat": "RSS MB"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes",
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 150 },
              { "color": "red", "value": 180 }
            ]
          }
        }
      },
      "options": { "tooltip": { "mode": "single" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },

    {
      "id": 14,
      "title": "📋 Logs Recentes",
      "type": "logs",
      "gridPos": { "x": 8, "y": 26, "w": 16, "h": 6 },
      "datasource": { "type": "loki", "uid": "Loki" },
      "targets": [{
        "expr": "{namespace=\"wizard\", container=\"wizard-intelligence-network\"} | json",
        "legendFormat": ""
      }],
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": false,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    }

  ]
}